# SignCall — Environment Variables
# Copy this file to .env and fill in YOUR values
# NEVER commit .env to git

# MongoDB Atlas connection string
# Replace <username>, <password>, <cluster> with your values
# Database name: sign_call  (will be auto-created by MongoDB)

MONGODB_URI=mongodb+srv://mulimanishashikumar_db_user:Shashi123@ac-3jupqp9.ppkhk8d.mongodb.net/sign_call?retryWrites=true&w=majority&appName=projectsand

# JWT secret — use a long random string, never share this
JWT_SECRET=replace_with_a_long_random_secret_minimum_32_characters

# Token expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Environment
NODE_ENV=production
